    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="77.243"/>
            <ColumnDefinition Width="334.757"/>
            <!-- Panel Izquierdo -->
            <ColumnDefinition Width="0"/>
            <!-- Separación -->
            <ColumnDefinition/>
            <!-- Panel Derecho -->
        </Grid.ColumnDefinitions>

        <!-- Cabecera Izquierda -->
        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16" Grid.ColumnSpan="2">
            <TextBlock Text="Nombre" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextLight}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Path=Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     FontSize="16" Padding="8" MaxWidth="400" HorizontalAlignment="Stretch"
                     ToolTip="Nombre de la configuración"/>
        </StackPanel>

        <!-- Direcciones de Acotación -->
        <GroupBox Grid.Row="1" Grid.Column="0" Header="Direcciones de Acotación" Margin="0,0,0,69" Grid.ColumnSpan="2" Grid.RowSpan="2">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Planta y Cotas -->
                <Grid Grid.Row="1" Grid.Column="1" Width="280" Height="220" Margin="8">
                    <Viewbox Child="{StaticResource Plan}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <Viewbox Child="{StaticResource BottomDimensions}" VerticalAlignment="Center" HorizontalAlignment="Center"
                             Visibility="{Binding IsChecked, Converter={StaticResource BooleanToVisibilityConverter}, ElementName=BtBottomDimensions}"/>
                    <Viewbox Child="{StaticResource TopDimensions}" VerticalAlignment="Center" HorizontalAlignment="Center"
                             Visibility="{Binding IsChecked, Converter={StaticResource BooleanToVisibilityConverter}, ElementName=BtTopDimensions}"/>
                    <Viewbox Child="{StaticResource RightDimensions}" VerticalAlignment="Center" HorizontalAlignment="Center"
                             Visibility="{Binding IsChecked, Converter={StaticResource BooleanToVisibilityConverter}, ElementName=BtRightDimensions}"/>
                    <Viewbox Child="{StaticResource LeftDimensions}" VerticalAlignment="Center" HorizontalAlignment="Center"
                             Visibility="{Binding IsChecked, Converter={StaticResource BooleanToVisibilityConverter}, ElementName=BtLeftDimensions}"/>
                </Grid>

                <!-- Botones Perimetrales -->
                <ToggleButton Grid.Row="0" Grid.Column="1" Name="BtTopDimensions" Margin="0,0,0,8" 
                              Content="Arriba" Padding="20,6" HorizontalAlignment="Center"
                              IsChecked="{Binding Path=TopDimensions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <ToggleButton Grid.Row="1" Grid.Column="0" Name="BtLeftDimensions" Margin="0,0,8,0" 
                              Content="Izq." Padding="12,20" VerticalAlignment="Center"
                              IsChecked="{Binding Path=LeftDimensions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <ToggleButton Grid.Row="1" Grid.Column="2" Name="BtRightDimensions" Margin="8,0,0,0" 
                              Content="Der." Padding="12,20" VerticalAlignment="Center"
                              IsChecked="{Binding Path=RightDimensions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <ToggleButton Grid.Row="2" Grid.Column="1" Name="BtBottomDimensions" Margin="0,8,0,0" 
                              Content="Abajo" Padding="20,6" HorizontalAlignment="Center"
                              IsChecked="{Binding Path=BottomDimensions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </GroupBox>

        <!-- Cabecera Derecha -->
        <TextBlock Grid.Row="0" Grid.Column="3" 
                   Text="Cadenas de Cotas" 
                   FontWeight="SemiBold" FontSize="18" Foreground="{StaticResource TextDark}" 
                   VerticalAlignment="Top" Margin="0,54,0,0" Height="24"/>

        <!-- Grid de Cadenas -->
        <DataGrid Grid.Row="1" Grid.Column="3" Name="DgChains" AutoGenerateColumns="False"
                  ItemsSource="{Binding Path=Chains, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  CanUserAddRows="False" CanUserSortColumns="False" 
                  SelectionMode="Single" Margin="0,4,0,69" BorderThickness="1"
                  HeadersVisibility="Column" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Grid.RowSpan="2">
            <DataGrid.Columns>
                <!-- Nombre -->
                <DataGridTextColumn Header="Cadena" Binding="{Binding Path=DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    IsReadOnly="True" MinWidth="100"/>

                <!-- Desplazamiento -->
                <DataGridTemplateColumn Header="Desplaz. (mm)">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding Source={x:Static configurations:Constants.ElementOffsets}}"
                                      SelectedItem="{Binding Path=ElementOffset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="4,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Muros">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Path=Walls, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Vanos">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Path=Openings, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                      Visibility="{Binding Path=IntersectingWallsAndOpeningsVisibility, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>


                <DataGridTemplateColumn Header="Ejes">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Path=Grids, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>


                <DataGridTemplateColumn Header="Extremos">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Path=Overall, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Acciones -->
                <DataGridTemplateColumn Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource DangerButtonStyle}" Name="BtDeleteSelectedChain" Padding="6,2" MinWidth="0"
                                    ToolTip="Eliminar cadena" Click="BtDeleteSelectedChain_OnClick" Margin="4,2"
                                    HorizontalAlignment="Right">
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                              Fill="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Button}, Path=Foreground}"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Botones de Acción Globales -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderGray}" Margin="0,16,0,0" Padding="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="+ Agregar configuración" Click="BtAddRow_OnClick" FontSize="14" FontWeight="SemiBold"
                        Padding="16,8" Name="BtAddRow"/>

                <Button Grid.Column="2" Content="Guardar Cambios" Click="BtAccept_OnClick" Name="BtAccept"
                        Style="{StaticResource PrimaryButtonStyle}" FontSize="14" Padding="32,8"/>
            </Grid>
        </Border>

    </Grid>
</Window>
