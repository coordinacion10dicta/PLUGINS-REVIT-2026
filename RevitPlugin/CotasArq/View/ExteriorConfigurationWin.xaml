                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:configurations="clr-namespace:PluginCotasExteriores.Configurations"
                      SizeToContent="WidthAndHeight" ResizeMode="CanResizeWithGrip"
                      MinWidth="1200" MinHeight="420"
                      WindowStartupLocation="CenterScreen"
                      PreviewKeyDown="ExteriorConfigurationWin_OnPreviewKeyDown"
                      Loaded="ExteriorConfiguration_OnLoaded"
                      Background="{DynamicResource BackgroundLight}"
                      FontFamily="Segoe UI"
                      Title="Edición de Configuración de Cotas">

