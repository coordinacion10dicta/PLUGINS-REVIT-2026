                <Path Data="M 25.135413 87.979163 V 45.64583" Stroke="{StaticResource PrimaryBlue}" StrokeThickness="1"/>
                <Path Data="M 18.520833 80.041667 V 53.583334" Stroke="{StaticResource PrimaryBlue}" StrokeThickness="1"/>
