<Window x:Class="MiNamespace.UI.UiGenerateDescriptions"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar Disciplina"
        Height="250" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Seleccione disciplina"
                   FontSize="16"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- Botones dinámicos -->
        <WrapPanel x:Name="panelDisciplinas"
                   Grid.Row="1"
                   HorizontalAlignment="Center"/>

        <Button Grid.Row="2"
                Content="Abrir bandeja de revisión"
                HorizontalAlignment="Center"
                Margin="0,15,0,0"
                Padding="14,6"
                Click="BtnLearningView_Click"/>

    </Grid>
</Window>
