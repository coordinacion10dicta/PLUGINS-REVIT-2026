<Window x:Class="PluginCotasExteriores.View.SettingsWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      SizeToContent="WidthAndHeight" Loaded="SettingsWindow_OnLoaded"
                      Closed="SettingsWindow_OnClosed"
                      Title="Configuración de Cotas"
                      ResizeMode="NoResize"
                      WindowStartupLocation="CenterScreen"
                      Background="{DynamicResource BackgroundLight}"
                      FontFamily="Segoe UI"
                      MinWidth="550">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PluginCotasExteriores;component/View/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Perfiles de Configuración -->
        <GroupBox Grid.Row="0" Header="Perfil de Configuración" Margin="0,0,0,16">
            <Grid Margin="12,12,12,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource TextLight}" Margin="0,0,0,4"><Run Text="Seleccionar configuración activa"/><Run Language="es-mx" Text=" de Cota"/><Run Text=":"/></TextBlock>
                    <ComboBox Name="CbExteriorConfigurations"
                              HorizontalAlignment="Stretch" Padding="8,6" FontSize="14"
                              SelectionChanged="CbExteriorConfigurations_OnSelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Path=Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Name="BtAddNewExteriorConfiguration" Margin="0,0,8,0" Padding="12,6"
                            Click="BtAddNewExteriorConfiguration_OnClick"
                            ToolTip="Crear nueva configuración" ToolTipService.InitialShowDelay="100">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="16" Height="16" Margin="0,0,6,0">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M19,11H15V15H13V11H9V9H13V5H15V9H19M20,2H8A2,2 0 0,0 6,4V16A2,2 0 0,0 8,18H20A2,2 0 0,0 22,16V4A2,2 0 0,0 20,2M4,6H2V20A2,2 0 0,0 4,22H18V20H4V6Z"
                                          Fill="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Button}, Path=Foreground}" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Nuevo" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Name="BtEditExteriorConfiguration" Margin="0,0,8,0" Padding="12,6"
                            Click="BtEditExteriorConfiguration_OnClick" Style="{StaticResource PrimaryButtonStyle}"
                            ToolTip="Editar configuración seleccionada" ToolTipService.InitialShowDelay="100">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="16" Height="16" Margin="0,0,6,0">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"
                                          Fill="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Button}, Path=Foreground}" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Editar" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button Name="BtDeleteExteriorConfiguration" Padding="12,6"
                            Click="BtDeleteExteriorConfiguration_OnClick" Style="{StaticResource DangerButtonStyle}"
                            ToolTip="Eliminar configuración seleccionada" ToolTipService.InitialShowDelay="100">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="16" Height="16" Margin="0,0,6,0">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                          Fill="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Button}, Path=Foreground}" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Eliminar" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Ajustes Geométricos Generales -->
        <GroupBox Grid.Row="1" Header="Tolerancias Geométricas">
            <Grid Margin="12,16,12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Espesor Mínimo Muro -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Espesor mín. de muro considerado:" VerticalAlignment="Center" Foreground="{StaticResource TextDark}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBox Name="TbMinWallWidth" Width="70" TextChanged="TextBoxBase_OnTextChanged" Padding="6,4" HorizontalContentAlignment="Right"/>
                        <TextBlock Text="mm" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource TextLight}"/>
                    </StackPanel>
                </Grid>

                <!-- Distancia mínima caras -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Tolerancia entre caras de muro:" VerticalAlignment="Center" Foreground="{StaticResource TextDark}" TextWrapping="Wrap"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Si &lt; a " VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Name="TbExteriorFaceMinWidthBetween" Width="60" TextChanged="TextBoxBase_OnTextChanged" Padding="6,4" HorizontalContentAlignment="Right"/>
                        <TextBlock Text=" mm," VerticalAlignment="Center" Margin="4,0,8,0"/>
                        <TextBlock Text="eliminar cara" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Name="CbExteriorMinWidthFaceRemove" Width="90" Padding="8,4">
                            <ComboBoxItem Content="Menor"/>
                            <ComboBoxItem Content="Mayor"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Grid>
        </GroupBox>
        
    </Grid>
</Window>
